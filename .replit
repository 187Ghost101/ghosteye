run = "python3 ghosteye_proxy.py 8082"

entrypoint = "python3 ghosteye_proxy.py 8082"

[env]
PYTHONUNBUFFERED = "1"
PORT = "8082"

[packager]
language = "python3"
ignoredDirs = ["__pycache__", ".git", "node_modules"]

[nix]
channel = "stable-23_11"

[gitHubImport]
requiredFiles = [".replit", "replit.nix", "ghosteye_proxy.py", "index.html"]
